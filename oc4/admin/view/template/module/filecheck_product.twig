<div class="p-3">
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">{{ text_workflow }}</label>
        <div class="col-sm-10">
            <select name="filecheck_workflow_id" class="form-select" style="max-width:400px;">
                <option value="none" {% if settings.workflow_id == 'none' or not settings.workflow_id %}selected{% endif %}>
                    {{ text_none }}
                </option>
                <option value="global" {% if settings.workflow_id == 'global' %}selected{% endif %}>
                    {{ text_global }}{% if default_workflow_id %} ({{ default_workflow_id }}){% endif %}
                </option>
                {% for wf in workflows %}
                    {% if wf.id is defined and wf.title is defined %}
                        <option value="{{ wf.id }}" {% if settings.workflow_id == wf.id %}selected{% endif %}>
                            {{ wf.title }} ({{ wf.id }})
                        </option>
                    {% endif %}
                {% endfor %}
            </select>
            <div class="form-text">Select the Filecheck workflow for this product. "None" disables the widget.</div>
        </div>
    </div>

    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">{{ text_connector }}</label>
        <div class="col-sm-10">
            <select name="filecheck_connector_id" class="form-select" style="max-width:400px;">
                <option value="">{{ text_none }}</option>
                {% for cn in connectors %}
                    {% if cn.id is defined and cn.title is defined %}
                        <option value="{{ cn.id }}" {% if settings.connector_id == cn.id %}selected{% endif %}>
                            {{ cn.title }} ({{ cn.id }})
                        </option>
                    {% endif %}
                {% endfor %}
            </select>
            <div class="form-text">Optional. Syncs Filecheck file details back to elements on this product page.</div>
        </div>
    </div>

    <input type="hidden" name="filecheck_product_id_loaded" value="{{ product_id }}">
</div>
